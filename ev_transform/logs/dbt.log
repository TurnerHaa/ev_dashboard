  create  table "postgres"."public"."evs_atomic__dbt_tmp"
  
  
    as
  
  (
    WITH ev_data AS (
    SELECT * FROM "postgres"."public"."ev_registrations"
),
closure AS (
    SELECT * FROM "postgres"."public"."region_closure"
)

SELECT
    e.region_ons,
    e.quarter,
    e.fuel_type,
    e.vehicles
FROM "postgres"."public"."ev_registrations" e
WHERE NOT EXISTS (
    SELECT 1 
    FROM closure rc
    -- We check if ANY data exists for a descendant in this quarter
    INNER JOIN "postgres"."public"."ev_registrations" e_child
        ON e_child.region_ons = rc.descendant_ons
        AND e_child.quarter = e.quarter
    WHERE rc.ancestor_ons = e.region_ons
      AND rc.descendant_ons <> e.region_ons
)
  );
  
