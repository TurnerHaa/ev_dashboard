  create  table "postgres"."public"."evs_atomic__dbt_tmp"
  
  
    as
  
  (
    WITH ev_data AS (
    SELECT * FROM "postgres"."public"."ev_registrations"
),
closure AS (
    SELECT * FROM "postgres"."public"."region_closure"
)

SELECT
  e.region_ons,
  e.quarter,
  e.fuel_type,
  e.vehicles
FROM ev_data e
LEFT JOIN closure rc 
  ON rc.ancestor_ons = e.region_ons 
  AND rc.descendant_ons <> e.region_ons
LEFT JOIN ev_data e_child 
  ON e_child.region_ons = rc.descendant_ons
  AND e_child.quarter = e.quarter
  AND e_child.fuel_type = e.fuel_type
WHERE e_child.region_ons IS NULL
  );
  
